{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "summary",
    "recommended_next_step",
    "requires_human_approval",
    "approval_reason",
    "approved_plan_run_id",
    "worktree_path",
    "files_touched",
    "commands_attempted",
    "tests_requested_or_run",
    "blocked_actions",
    "risks",
    "open_questions"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "const": "execute"
    },
    "summary": {
      "type": "string"
    },
    "recommended_next_step": {
      "type": "string"
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "approval_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "approved_plan_run_id": {
      "type": "string"
    },
    "worktree_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands_attempted": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests_requested_or_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

