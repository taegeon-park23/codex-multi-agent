{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OrchestrationPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "summary",
    "recommended_next_step",
    "requires_human_approval",
    "approval_reason",
    "proposed_worktrees",
    "proposed_subtasks",
    "per_agent_findings",
    "tests_requested_or_run",
    "risks",
    "open_questions"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "mode": { "type": "string", "const": "plan" },
    "summary": { "type": "string" },
    "recommended_next_step": { "type": "string" },
    "requires_human_approval": { "type": "boolean" },
    "approval_reason": { "type": ["string", "null"] },
    "proposed_worktrees": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose", "base_ref"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "base_ref": { "type": ["string", "null"] }
        }
      }
    },
    "proposed_subtasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "owner_role", "mode", "depends_on"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "owner_role": { "type": "string" },
          "mode": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "per_agent_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agent", "summary", "details", "used_multi_agent"],
        "properties": {
          "agent": { "type": "string" },
          "summary": { "type": "string" },
          "details": {
            "type": "array",
            "items": { "type": "string" }
          },
          "used_multi_agent": { "type": "boolean" }
        }
      }
    },
    "tests_requested_or_run": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}