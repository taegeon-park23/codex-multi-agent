{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "summary",
    "recommended_next_step",
    "requires_human_approval",
    "approval_reason",
    "target_run_id",
    "findings",
    "severity_summary",
    "tests_requested_or_run",
    "risks",
    "open_questions"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "const": "review"
    },
    "summary": {
      "type": "string"
    },
    "recommended_next_step": {
      "type": "string"
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "approval_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_run_id": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "severity",
          "summary"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "severity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "properties": {
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tests_requested_or_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
